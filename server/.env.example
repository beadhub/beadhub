POSTGRES_USER=aweb
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aweb

AWEB_PORT=8000
REDIS_PORT=6379
POSTGRES_PORT=5432

# Optional but recommended for custodial signing.
# Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
AWEB_CUSTODY_KEY=

# Optional managed namespace domain, e.g. aweb.example.com
AWEB_MANAGED_DOMAIN=

AWEB_LOG_JSON=true
